# ── App ──
APP_NAME=onepage-api
DEBUG=true
API_V1_PREFIX=/api
SECRET_KEY=change-me-in-production
ANONYMOUS_USER_HEADER=X-Anonymous-User-Id
MAX_UPLOAD_SIZE_MB=20

# ── Database (复用 training-postgres 容器) ──
DATABASE_URL=postgresql+asyncpg://training:training123@training-postgres:5432/onepage
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis (复用 training-redis 容器, 使用 DB 2/3/4) ──
REDIS_URL=redis://training-redis:6379/2
CELERY_BROKER_URL=redis://training-redis:6379/3
CELERY_RESULT_BACKEND=redis://training-redis:6379/4

# ── MinIO (复用 training-minio 容器) ──
MINIO_ENDPOINT=training-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=onepage-uploads
MINIO_BUCKET_MATERIALS=onepage-materials
MINIO_SECURE=false

# ── AI Models ──
SENSEVOICE_API_URL=
SENSEVOICE_API_KEY=
QWEN_VL_API_URL=
QWEN_VL_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_API_KEY=
AI_REQUEST_TIMEOUT=60
AI_MAX_RETRIES=3

# ── Weather ──
WEATHER_API_URL=
WEATHER_API_KEY=
WEATHER_CACHE_TTL=86400

# ── Rate Limit ──
RATE_LIMIT_PER_MINUTE=30

# ── SSE ──
SSE_TTL=3600

# ── Celery ──
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
