# ── App ──
APP_NAME=onepage-api
DEBUG=true
API_V1_PREFIX=/api
PUBLIC_API_BASE_URL=/api
SECRET_KEY=change-me-in-production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ANONYMOUS_USER_HEADER=X-Anonymous-User-Id
MAX_UPLOAD_SIZE_MB=20
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp","image/svg+xml"]
ALLOWED_AUDIO_TYPES=["audio/wav","audio/mp3","audio/m4a","audio/webm"]
LAYOUT_ENGINE_VERSION=v2
BUILD_COMMIT_SHA=development

# ── Database (复用 training-postgres 容器) ──
DATABASE_URL=postgresql+asyncpg://training:training123@training-postgres:5432/onepage
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis (复用 training-redis 容器, 使用 DB 2/3/4) ──
REDIS_URL=redis://training-redis:6379/2
CELERY_BROKER_URL=redis://training-redis:6379/3
CELERY_RESULT_BACKEND=redis://training-redis:6379/4

# ── MinIO (复用 training-minio 容器) ──
MINIO_ENDPOINT=training-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=onepage-uploads
MINIO_BUCKET_MATERIALS=onepage-materials
MINIO_SECURE=false

# ── AI Models ──
SENSEVOICE_API_URL=
SENSEVOICE_API_KEY=
QWEN_VL_API_URL=
QWEN_VL_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_API_KEY=
AI_REQUEST_TIMEOUT=60
AI_MAX_RETRIES=3
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_REVIEW_ENABLED=true
VISION_REVIEW_PROVIDER=dashscope
VISION_REVIEW_MODEL=qwen3.5-omni-flash
VISION_REVIEW_TIMEOUT_SECONDS=10
VISION_REVIEW_MAX_RETRIES=1
VISION_REVIEW_MAX_CANDIDATES=8
VISION_REVIEW_MODE=best_effort
VISION_REVIEW_FAIL_OPEN=false
VISION_REVIEW_MAX_DATA_URL_BYTES=8000000
VISION_REVIEW_CONTACT_SHEET_MIME=image/jpeg
VISION_REVIEW_CIRCUIT_BREAKER_ENABLED=true
VISION_REVIEW_CIRCUIT_BREAKER_THRESHOLD=3
VISION_REVIEW_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300

# ── Weather ──
AMAP_WEB_SERVICE_KEY=
AMAP_REVERSE_GEOCODE_URL=https://restapi.amap.com/v3/geocode/regeo
AMAP_WEATHER_URL=https://restapi.amap.com/v3/weather/weatherInfo
WEATHER_CACHE_TTL=600
DEFAULT_WEATHER_LOCATION=深圳
AMAP_WEATHER_MCP_URL=http://127.0.0.1:8001/mcp
MCP_TOOL_TIMEOUT_SECONDS=10
MCP_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PORT=8001
MCP_PATH=/mcp
DEFAULT_TIMEZONE=Asia/Shanghai

# ── Logging ──
PIPELINE_LOG_LEVEL=INFO
PIPELINE_DEBUG_TRACE=false
LOG_EXTERNAL_LIBRARIES=WARNING
LOG_SSE_PROGRESS=false
LOG_FULL_CANDIDATES=false
LOG_MCP_PROTOCOL=false

# ── Rate Limit ──
RATE_LIMIT_PER_MINUTE=30

# ── SSE ──
SSE_TTL=3600

# ── Celery ──
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600
