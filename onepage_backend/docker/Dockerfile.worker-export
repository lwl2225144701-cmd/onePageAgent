FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc curl chromium fonts-noto-cjk && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir -e ".[api,export]" 2>/dev/null || pip install --no-cache-dir $(grep -E '^    "[^"]+"' pyproject.toml | sed 's/",\?$//;s/    "//')
RUN pip install playwright && playwright install chromium

COPY . .

CMD ["celery", "-A", "app.workers.celery_app", "worker", "-Q", "export_queue", "--loglevel=info", "--concurrency=1"]
